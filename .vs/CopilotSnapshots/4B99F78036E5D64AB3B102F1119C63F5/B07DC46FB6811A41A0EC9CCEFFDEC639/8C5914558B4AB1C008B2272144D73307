    <style>
        /* ===== СТИЛИ АККОРДЕОНА ===== */

        /* Контейнер одного пункта правил */
        .accordion-item {
            border: 1px solid rgba(139, 92, 246, 0.2);
            border-radius: 0.75rem;
            margin-bottom: 0.75rem;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .accordion-item:hover {
            border-color: rgba(139, 92, 246, 0.4);
        }

        /* Заголовок аккордеона (кнопка) */
        .accordion-header {
            width: 100%;
            padding: 1.25rem 1.5rem;
            background: rgba(18, 10, 26, 0.6);
            border: none;
            color: #e2e8f0;
            font-size: 1rem;
            font-weight: 500;
            text-align: left;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
        }

        .accordion-header:hover {
            background: rgba(139, 92, 246, 0.1);
        }

        /* Активное состояние заголовка */
        .accordion-header.active {
            background: rgba(139, 92, 246, 0.15);
            border-bottom: 1px solid rgba(139, 92, 246, 0.2);
        }

        /* Иконка стрелки */
        .accordion-icon {
            width: 1.25rem;
            height: 1.25rem;
            transition: transform 0.3s ease;
            color: #a78bfa;
            flex-shrink: 0;
            /* Запрещаем сжатие иконки */
            margin-left: 1rem;
            /* Отступ от текста */
        }

        /* Поворот стрелки при открытии */
        .accordion-header.active .accordion-icon {
            transform: rotate(90deg);
        }

        /* Контейнер содержимого (скрыт по умолчанию) */
        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out, padding 0.3s ease;
            background: rgba(10, 8, 16, 0.4);
        }

        /* Открытое состояние содержимого */
        .accordion-content.active {
            /* max-height управляется через JS (используем scrollHeight) */
            transition: max-height 0.5s ease-in;
        }

        /* Тело с текстом правил */
        .accordion-body {
            padding: 0 1.5rem;
            color: #a78bfa;
            line-height: 1.6;
        }

        .accordion-content.active .accordion-body {
            padding: 1.5rem;
        }

        /* ===== ПЕРЕКЛЮЧАТЕЛЬ МУЛЬТИВЫБОРА ===== */

        .toggle-switch {
            position: relative;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
        }

        .toggle-input {
            display: none;
        }

        .toggle-slider {
            width: 3rem;
            height: 1.5rem;
            background: rgba(139, 92, 246, 0.2);
            border-radius: 9999px;
            position: relative;
            transition: all 0.3s ease;
            border: 1px solid rgba(139, 92, 246, 0.3);
        }

        .toggle-slider::before {
            content: '';
            position: absolute;
            width: 1.25rem;
            height: 1.25rem;
            background: #8B5CF6;
            border-radius: 50%;
            top: 0.125rem;
            left: 0.125rem;
            transition: all 0.3s ease;
        }

        .toggle-input:checked+.toggle-slider {
            background: rgba(139, 92, 246, 0.4);
        }

        .toggle-input:checked+.toggle-slider::before {
            transform: translateX(1.5rem);
        }

        /* ===== ПОДСВЕТКА ПУНКТОВ ПРАВИЛ ===== */

        .rule-highlight {
            background: rgba(139, 92, 246, 0.05);
            border-left: 3px solid #8B5CF6;
            padding: 1rem;
            /* Внутренние отступы как в разделе 2 */
            margin: 0.5rem 0;
            scroll-margin-top: 5rem;
            /* Отступ при прокрутке к пункту, чтобы не скрывался под фикс. навбаром */
        }

        /* ===== ИСПРАВЛЕНИЕ ПЕРЕПОЛНЕНИЯ ===== */

        /* Перенос длинных слов (для 2.10 и других длинных пунктов) */
        .accordion-body p {
            word-wrap: break-word;
            /* Перенос слов */
            overflow-wrap: break-word;
            /* Современный аналог */
            hyphens: auto;
            /* Автоматические переносы через дефис */
        }

        /* Уменьшение отступов на мобильных устройствах */
        @media (max-width: 640px) {
            .accordion-header {
                padding: 1rem;
                font-size: 0.875rem;
            }

            .accordion-body {
                padding: 0 1rem;
            }

            .accordion-content.active .accordion-body {
                padding: 1rem;
            }

            /* Уменьшаем отступ у иконки на мобильных */
            .accordion-icon {
                margin-left: 0.5rem;
            }
        }
    </style>
</head>

